# -----------------------------------------------------------------------------
# 1. RUST BUILD ARTIFACTS
# -----------------------------------------------------------------------------
# The build directory (contains all compiled binaries and deps)
/target/

# Backup files generated by Rust
**/*.rs.bk

# -----------------------------------------------------------------------------
# 2. ENVIRONMENT & SECRETS (CRITICAL)
# -----------------------------------------------------------------------------
# Never commit environment variables or secrets!
.env
.env.local
# Security & PKI Artifacts
certs/
*.pem
*.key
*.crt
*.csr
*.srl  # <--- Add this

# -----------------------------------------------------------------------------
# 3. IDE & EDITOR SETTINGS
# -----------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ / RustRover
.idea/
*.iml

# Vim / Neovim 
*.swp
*.swo
.netrwhist
Session.vim

# MacOS
.DS_Store

# -----------------------------------------------------------------------------
# 4. DATABASE & MIGRATIONS
# -----------------------------------------------------------------------------
# Ignore local SQLite DBs if you use them for testing
*.db
*.db-shm
*.db-wal

# DO NOT ignore your SQL migrations!
# !migrations/ 

# -----------------------------------------------------------------------------
# 5. TESTING & TOOLS
# -----------------------------------------------------------------------------
# Coverage reports (if you use tarpaulin or grcov)
coverage/
cobertura.xml
tarpaulin-report.html

